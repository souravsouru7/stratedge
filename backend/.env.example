# Required
MONGO_URI=mongodb://localhost:27017/yourdb
JWT_SECRET=your-secret

# Cloudinary (for screenshot upload)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Optional: Google Vision OCR for Indian market (high accuracy vs Tesseract)
# Path to service account JSON. If unset, uses backend/config/even-plating-*.json
# GOOGLE_APPLICATION_CREDENTIALS=./config/even-plating-440012-a9-0dc833ee5b8e.json

# Optional: AI fallback for Indian trade extraction when parsing fails
# If set, uses OpenAI gpt-4o-mini when symbol or profit is missing from OCR
# OPENAI_API_KEY=sk-...
