# ==========================================
# STRATEDGE BACKEND ENV TEMPLATE
# ==========================================
# Copy to backend/.env for local development.
# In production, inject these values through your platform's secret manager.

# ==========================================
# CORE APP SECRETS (REQUIRED)
# ==========================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=warn
ALLOWED_ORIGINS=http://localhost:3000
CORS_DEBUG=false
TIMEZONE_OFFSET_HOURS=0
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ==========================================
# CLOUDINARY (REQUIRED FOR IMAGE UPLOADS)
# ==========================================
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=
UPLOAD_MAX_FILE_SIZE_BYTES=2097152

# ==========================================
# FIREBASE ADMIN (REQUIRED FOR GOOGLE LOGIN)
# ==========================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Store private keys with escaped newlines in .env/secret managers: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY=

# ==========================================
# GOOGLE CLOUD VISION (OPTIONAL OCR FALLBACK)
# ==========================================
GOOGLE_VISION_PROJECT_ID=
GOOGLE_VISION_CLIENT_EMAIL=
GOOGLE_VISION_PRIVATE_KEY=

# ==========================================
# AI PROVIDERS
# ==========================================
OPENAI_API_KEY=
OPENAI_TRADE_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TRADE_MODEL=gemini-2.5-flash

# ==========================================
# SMTP
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@stratedge.live

# ==========================================
# RAZORPAY
# ==========================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ==========================================
# REDIS / BULLMQ (required for OCR queue + worker)
# ==========================================
# If REDIS_URL is set, it wins. Otherwise UPSTASH_REDIS_REST_URL + TOKEN build a rediss:// URL.
# ENOTFOUND for *.upstash.io = wrong/deleted instance — use current URL from Upstash dashboard.
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==========================================
# DATA CLEANUP & RETENTION CONFIGURATION
# ==========================================
ENABLE_DATA_CLEANUP_CRON=true
DATA_CLEANUP_CRON_SCHEDULE=0 3 * * *
ENABLE_WEEKLY_REPORTS_CRON=true
WEEKLY_REPORTS_CRON=0 9 * * *
CLEANUP_RAW_OCR_DAYS=7
CLEANUP_AI_RESPONSE_DAYS=7
CLEANUP_IMAGES_DAYS=0

# ==========================================
# OCR WORKER PERFORMANCE
# ==========================================
OCR_WORKER_CONCURRENCY=5
OCR_WORKER_LOCK_DURATION_MS=300000
OCR_JOB_ATTEMPTS=3
OCR_JOB_BACKOFF_MS=5000
CLEANUP_BATCH_SIZE=100

# ==========================================
# RATE LIMITS
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
STATUS_RATE_LIMIT_WINDOW_MS=60000
STATUS_RATE_LIMIT_MAX_REQUESTS=30

# ==========================================
# TIMEOUTS
# ==========================================
API_REQUEST_TIMEOUT_MS=15000
OCR_SERVICE_TIMEOUT_MS=90000
AI_SERVICE_TIMEOUT_MS=45000
DB_OPERATION_TIMEOUT_MS=10000
EXTERNAL_API_TIMEOUT_MS=10000
PROCESSING_TIMEOUT_MS=300000
