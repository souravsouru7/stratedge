# ==========================================
# DATA CLEANUP & RETENTION CONFIGURATION
# ==========================================
# Copy these settings to your .env file
# Adjust values based on your needs

# Enable/disable automated cleanup
# Set to false to disable the cron job completely
ENABLE_DATA_CLEANUP_CRON=true

# Cron schedule for cleanup job (server time)
# Default: Daily at 3:00 AM
# Format: minute hour day month weekday
DATA_CLEANUP_CRON_SCHEDULE=0 3 * * *

# ==========================================
# RETENTION PERIODS (in days)
# ==========================================
# How long to keep OCR/AI data before cleanup
# Set to 0 to disable cleaning of that field

# Raw OCR text retention (default: 7 days)
CLEANUP_RAW_OCR_DAYS=7

# AI raw response retention (default: 7 days)
CLEANUP_AI_RESPONSE_DAYS=7

# Image cleanup retention (default: 0 = disabled)
# ⚠️ WARNING: Setting this > 0 will IRREVERSIBLY delete images from Cloudinary!
CLEANUP_IMAGES_DAYS=0

# ==========================================
# PERFORMANCE SETTINGS
# ==========================================

# Number of records to process per batch
# Lower = less memory, slower cleanup
# Higher = more memory, faster cleanup
# Recommended: 50-200 depending on DB size
CLEANUP_BATCH_SIZE=100

# ==========================================
# EXAMPLE SCENARIOS
# ==========================================

# Conservative (keep data longer):
# CLEANUP_RAW_OCR_DAYS=14
# CLEANUP_AI_RESPONSE_DAYS=14
# CLEANUP_BATCH_SIZE=50

# Aggressive (clean quickly):
# CLEANUP_RAW_OCR_DAYS=3
# CLEANUP_AI_RESPONSE_DAYS=3
# CLEANUP_BATCH_SIZE=200

# Keep forever (no cleanup):
# CLEANUP_RAW_OCR_DAYS=0
# CLEANUP_AI_RESPONSE_DAYS=0

# Enable image cleanup (⚠️ DANGEROUS):
# CLEANUP_IMAGES_DAYS=30
